# Axon - Example Environment Variables
# Copy this file to .env and customize as needed

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_EMBED_MODEL=nomic-embed-text

# API Configuration
# Bind to localhost by default. For containerized runs (Docker/Compose/K8s), set AXON_HOST=0.0.0.0
# so the API is reachable from the host/UI container. Use 0.0.0.0 only for authenticated deployments behind network controls.
AXON_HOST=127.0.0.1
AXON_PORT=8000

# Vector Store Configuration
CHROMA_DATA_PATH=./chroma_data
BM25_INDEX_PATH=./bm25_index

# Logging
LOG_LEVEL=INFO

# Optional: FastAPI Configuration
FASTAPI_RELOAD=false
FASTAPI_WORKERS=1

# Optional: Streamlit Configuration
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
